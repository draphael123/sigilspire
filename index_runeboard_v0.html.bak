<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SIGILSPIRE</title>
<style>
  :root{
    --bg:#100b07; --panel:#221a10; --panel2:#2f2415; --edge:#4c3a22;
    --gold:#f0c968; --gold-dim:#9a7f44; --ember:#ff7a2f;
    --fire:#ff7033; --ice:#5fd4ff; --storm:#c07bff; --earth:#d19a52;
    --txt:#f3e8d5; --dim:#b39c78; --danger:#ff5c72; --good:#79e0a0;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%;}
  body{
    background:
      radial-gradient(1100px 600px at 50% -8%, #3a2410 0%, transparent 55%),
      radial-gradient(900px 500px at 50% 110%, #2a1608 0%, transparent 60%),
      #0c0805;
    color:var(--txt); font-family:'Segoe UI',system-ui,sans-serif;
    display:flex; align-items:center; justify-content:center; min-height:100vh;
    overflow-x:hidden; padding:14px;
  }
  #app{width:min(1040px,100%);}
  h1,h2,h3{font-family:'Georgia','Times New Roman',serif; letter-spacing:.02em;}
  .glow{text-shadow:0 0 18px rgba(255,122,47,.55), 0 0 6px rgba(240,201,104,.4);}
  button{font-family:inherit; cursor:pointer; color:var(--txt);}
  .btn{
    background:linear-gradient(180deg,var(--panel2),var(--panel));
    border:1px solid var(--edge); border-radius:10px; padding:10px 18px;
    font-size:15px; transition:.15s; box-shadow:0 2px 0 rgba(0,0,0,.5);
  }
  .btn:hover{border-color:var(--gold); transform:translateY(-1px);}
  .btn:active{transform:translateY(1px);}
  .btn.primary{background:linear-gradient(180deg,#c1531b,#7c3410); border-color:#ff8a44; color:#fff;}
  .btn.gold{background:linear-gradient(180deg,#a6802f,#6b4d18); border-color:var(--gold); color:#fff;}
  .btn:disabled{opacity:.4; cursor:not-allowed; transform:none;}

  /* sigils (SVG element glyphs) */
  .sigil{display:inline-flex; vertical-align:middle;}
  .sigil svg{width:1em; height:1em; display:block;}
  .sigil.fire{color:var(--fire);} .sigil.ice{color:var(--ice);}
  .sigil.storm{color:var(--storm);} .sigil.earth{color:var(--earth);}

  /* ---------- TITLE ---------- */
  #title{text-align:center; padding:34px 0;}
  #title h1{font-size:66px; color:var(--gold); letter-spacing:.08em; margin-bottom:6px;}
  #title .sub{color:var(--ember); font-size:16px; margin-bottom:8px; letter-spacing:.28em; text-transform:uppercase;}
  #title .tag{color:var(--dim); font-size:15px; margin:20px auto 26px; max-width:540px; line-height:1.7;}
  #title .tag b{color:var(--txt);}
  .hero-hint{display:flex; align-items:center; gap:14px; justify-content:center; margin:0 auto 22px; max-width:420px;
    background:linear-gradient(180deg,rgba(47,36,21,.6),rgba(34,26,16,.6)); border:1px solid var(--edge); border-radius:14px; padding:12px 18px;}
  .hero-hint .heroart{width:58px; height:70px; flex:0 0 auto; filter:drop-shadow(0 0 8px rgba(255,122,47,.4));}
  .hero-hint .ht{text-align:left;}
  .hero-hint .ht b{color:var(--gold); font-size:16px; font-family:serif;}
  .hero-hint .ht span{color:var(--dim); font-size:12.5px; display:block; margin-top:2px; line-height:1.4;}

  .reactguide{text-align:left; font-size:13px; color:var(--dim); line-height:1.9; background:rgba(0,0,0,.28); border:1px solid var(--edge); border-radius:12px; padding:14px 18px;}
  .reactguide .rg-title{color:var(--gold); font-family:serif; font-size:15px; margin-bottom:6px;}
  .reactguide b{color:var(--txt);}
  .reactguide .sigil{font-size:17px;}

  /* ---------- MAP ---------- */
  .map-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;}
  .map-header h2{color:var(--gold); font-size:24px;}
  .hp-pill{background:var(--panel); border:1px solid var(--edge); border-radius:20px; padding:6px 16px; font-size:15px;}
  .map{background:linear-gradient(180deg,rgba(34,26,16,.6),rgba(16,11,7,.7)); border:1px solid var(--edge); border-radius:14px; padding:20px; position:relative;}
  .map-row{display:flex; justify-content:center; gap:34px; margin:6px 0; position:relative; z-index:2;}
  .node{width:66px; height:66px; border-radius:14px; border:2px solid var(--edge); background:var(--panel);
    display:flex; flex-direction:column; align-items:center; justify-content:center; font-size:26px; position:relative; transition:.15s; color:var(--dim);}
  .node .ni{width:30px; height:30px;}
  .node .lbl{font-size:9px; letter-spacing:.05em; text-transform:uppercase; margin-top:3px;}
  .node.reachable{cursor:pointer; border-color:var(--gold); color:var(--gold); box-shadow:0 0 16px rgba(240,201,104,.3);}
  .node.reachable:hover{transform:scale(1.08); background:var(--panel2);}
  .node.done{opacity:.35; border-style:dashed;}
  .node.current{border-color:var(--good); box-shadow:0 0 18px rgba(121,224,160,.45);}
  .node.boss{width:82px; height:82px; border-color:var(--danger); color:var(--danger);}
  .node.boss .ni{width:40px; height:40px;}

  /* ---------- COMBAT ---------- */
  #combat{display:none; position:relative; border-radius:16px; overflow:hidden; padding:14px;}
  .tower-bg{position:absolute; inset:0; z-index:0; pointer-events:none;
    background:
      radial-gradient(680px 220px at 50% -30px, rgba(255,140,50,.20), transparent 70%),
      radial-gradient(400px 300px at 50% 30%, rgba(120,60,20,.12), transparent 70%),
      linear-gradient(180deg,#1b130b 0%, #0d0906 100%);}
  .tower-bg::before{content:''; position:absolute; inset:0;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,.028) 0 2px, transparent 2px 66px),
      repeating-linear-gradient(0deg, rgba(0,0,0,.28) 0 1px, transparent 1px 36px);
    -webkit-mask:linear-gradient(180deg,transparent, #000 45%); mask:linear-gradient(180deg,transparent,#000 45%);}
  .tower-bg::after{content:''; position:absolute; left:50%; top:6px; width:120px; height:180px; transform:translateX(-50%);
    background:radial-gradient(closest-side, rgba(255,150,60,.16), transparent);
    border-radius:60px 60px 0 0;}
  #combat > *:not(.tower-bg){position:relative; z-index:1;}

  .topbar{display:flex; align-items:center; gap:14px; flex-wrap:wrap;
    background:rgba(34,26,16,.82); border:1px solid var(--edge); border-radius:12px; padding:10px 16px; margin-bottom:12px;}
  .stat{display:flex; align-items:center; gap:7px; font-size:15px;}
  .stat .ic{width:20px; height:20px; color:var(--gold);}
  .bar{width:150px; height:16px; background:#000; border-radius:8px; overflow:hidden; border:1px solid var(--edge); position:relative;}
  .bar>span{display:block; height:100%; transition:width .3s;}
  .bar .lab{position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-size:11px; color:#fff; text-shadow:0 0 3px #000;}
  .hpfill{background:linear-gradient(90deg,#c0334a,#ff6b7f);}
  .block-badge{display:none; align-items:center; gap:4px; background:#2a3a52; border:1px solid #6fa0e0; border-radius:8px; padding:3px 9px; font-size:14px; color:#cfe4ff;}
  .block-badge.on{display:inline-flex;}
  .block-badge svg{width:14px; height:14px;}
  .energy-orbs{display:flex; gap:5px;}
  .orb{width:20px; height:20px; border-radius:50%; background:#2a2010; border:2px solid var(--edge);}
  .orb.on{background:radial-gradient(circle at 35% 30%,#fff,#ff9a44); border-color:#ffc38a; box-shadow:0 0 9px #ff7a2f;}

  .enemies{display:flex; justify-content:center; gap:26px; flex-wrap:wrap; min-height:190px; margin-bottom:4px; align-items:flex-end;}
  .enemy{width:154px; background:rgba(34,26,16,.7); border:2px solid var(--edge); border-radius:14px;
    padding:10px 10px 12px; text-align:center; cursor:pointer; transition:.15s; position:relative;}
  .enemy:hover{border-color:var(--gold);}
  .enemy.targeted{border-color:var(--gold); box-shadow:0 0 16px rgba(240,201,104,.4);}
  .enemy.dead{opacity:.22; pointer-events:none; filter:grayscale(1);}
  .enemy .sprite{height:74px; display:flex; align-items:flex-end; justify-content:center;}
  .enemy .sprite svg{width:74px; height:74px; filter:drop-shadow(0 3px 5px rgba(0,0,0,.5));}
  .enemy .sprite.boss svg{width:96px; height:96px;}
  .enemy.big{width:170px;}
  .enemy .ename{font-size:13px; color:var(--dim); margin:2px 0 6px;}
  .enemy .ebar{height:13px;}
  .enemy .ebar .lab{font-size:10px;}
  .intent{position:absolute; top:-14px; left:50%; transform:translateX(-50%);
    background:#160f08; border:1px solid var(--edge); border-radius:14px; padding:2px 10px;
    font-size:14px; white-space:nowrap; display:flex; align-items:center; gap:5px;}
  .intent svg{width:15px; height:15px;}
  .intent.atk{border-color:var(--danger); color:#ffb0bb;}
  .intent.def{border-color:#6fa0e0; color:#bcd8ff;}
  .intent.buff{border-color:var(--storm); color:#e0c0ff;}
  .estatus{position:absolute; bottom:-10px; left:50%; transform:translateX(-50%); display:flex; gap:4px;}
  .estatus span{background:#160f08; border:1px solid var(--edge); border-radius:10px; padding:1px 6px; font-size:11px; display:inline-flex; align-items:center; gap:3px;}
  .estatus svg{width:11px; height:11px;}

  .arena-mid{display:flex; align-items:stretch; justify-content:center; gap:18px; margin:10px 0 12px; flex-wrap:wrap;}

  /* hero panel */
  .hero-panel{width:170px; background:rgba(34,26,16,.75); border:2px solid var(--edge); border-radius:14px;
    padding:12px 12px 14px; display:flex; flex-direction:column; align-items:center; gap:8px;}
  .hero-panel .heroart{width:86px; height:104px; filter:drop-shadow(0 0 12px rgba(255,122,47,.45));}
  .hero-panel .hname{font-family:serif; color:var(--gold); font-size:15px;}
  .hero-panel .hbar{width:100%;}
  .aura-note{font-size:10.5px; color:var(--dim); text-align:center; line-height:1.4;}
  .aura-note b{color:var(--ember);}
  .brand-btn{width:100%; background:linear-gradient(180deg,#c1531b,#7c3410); border:1px solid #ff8a44; color:#fff;
    border-radius:10px; padding:8px 6px; font-size:12.5px; font-weight:bold; transition:.15s; display:flex; flex-direction:column; align-items:center; gap:1px;}
  .brand-btn small{font-weight:normal; font-size:10px; opacity:.85;}
  .brand-btn:hover:not(:disabled){box-shadow:0 0 14px rgba(255,122,47,.6);}
  .brand-btn:disabled{opacity:.35; cursor:not-allowed;}

  .board-wrap{display:flex; flex-direction:column; align-items:center; gap:8px;}
  .board{display:grid; grid-template-columns:repeat(3,84px); grid-template-rows:repeat(3,84px); gap:8px;
    background:rgba(0,0,0,.32); padding:10px; border-radius:14px; border:1px solid var(--edge); box-shadow:inset 0 0 30px rgba(0,0,0,.4);}
  .cell{width:84px; height:84px; border-radius:12px; border:2px dashed #3a2c18; display:flex; align-items:center; justify-content:center; position:relative; background:rgba(255,255,255,.015);}
  .cell.empty::after{content:''; width:16px; height:16px; border-radius:50%; border:1px dashed #4c3a22;}
  .rune{width:100%; height:100%; border-radius:10px; border:2px solid var(--edge);
    display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; transition:.12s; position:relative; user-select:none;
    background:linear-gradient(180deg,var(--panel2),var(--panel)); overflow:hidden;}
  .rune .glyph{font-size:32px; line-height:1;}
  .rune .glyph .sigil{filter:drop-shadow(0 0 6px currentColor);}
  .rune .rcost{position:absolute; top:3px; left:5px; font-size:11px; color:#fff; background:#7c3410; border:1px solid #ff8a44; border-radius:50%; width:18px; height:18px; display:flex; align-items:center; justify-content:center; z-index:2;}
  .rune .rname{font-size:9px; color:var(--dim); margin-top:2px; text-align:center; line-height:1.05; padding:0 2px;}
  .rune.fire{border-color:var(--fire);} .rune.ice{border-color:var(--ice);}
  .rune.storm{border-color:var(--storm);} .rune.earth{border-color:var(--earth);}
  .rune::before{content:''; position:absolute; inset:0; opacity:.10; background:radial-gradient(circle at 50% 38%, currentColor, transparent 62%);}
  .rune.fire::before{color:var(--fire);} .rune.ice::before{color:var(--ice);} .rune.storm::before{color:var(--storm);} .rune.earth::before{color:var(--earth);}
  .rune.castable{box-shadow:0 0 13px rgba(240,201,104,.5);}
  .rune.castable:hover{transform:translateY(-3px);}
  .rune.used{opacity:.35; filter:grayscale(.6);}
  .rune.dragging{opacity:.4;}
  .cell.dragover{border-color:var(--gold); background:rgba(240,201,104,.08);}
  .cell.ignited{animation:ignite 1s ease-out;}
  @keyframes ignite{0%{box-shadow:0 0 0 rgba(255,122,47,0);}30%{box-shadow:0 0 22px rgba(255,122,47,.9);}100%{box-shadow:0 0 0 rgba(255,122,47,0);}}

  .combat-right{display:flex; flex-direction:column; gap:10px; align-items:center; justify-content:center;}
  .endturn{background:linear-gradient(180deg,#a6802f,#6b4d18); border:2px solid var(--gold); border-radius:12px; padding:14px 22px; font-size:17px; color:#fff; font-weight:bold; display:flex; align-items:center; gap:8px;}
  .endturn svg{width:18px;height:18px;}
  .endturn:hover{box-shadow:0 0 18px rgba(240,201,104,.5);}
  .hint{font-size:12px; color:var(--dim); text-align:center; max-width:160px;}

  #log{height:82px; overflow-y:auto; background:rgba(0,0,0,.34); border:1px solid var(--edge); border-radius:10px; padding:8px 12px; font-size:13px; line-height:1.5;}
  #log .l{opacity:.5;} #log .l:last-child{opacity:1; color:#fff;}
  #log .react{color:var(--gold);} #log .aura{color:var(--ember); font-weight:bold;}

  .float{position:fixed; pointer-events:none; font-weight:bold; font-size:22px; z-index:50; text-shadow:0 0 6px #000; animation:floatUp 1s ease-out forwards;}
  @keyframes floatUp{0%{opacity:1; transform:translateY(0) scale(.8);}20%{transform:translateY(-6px) scale(1.15);}100%{opacity:0; transform:translateY(-46px) scale(1);}}
  .particle{position:fixed; width:8px; height:8px; border-radius:50%; pointer-events:none; z-index:55; background:radial-gradient(circle,#fff, var(--pc,#ff7a2f)); animation:burst .6s ease-out forwards;}
  @keyframes burst{to{transform:translate(var(--dx),var(--dy)) scale(.2); opacity:0;}}

  /* ---- ANIMATION LAYER ---- */
  /* idle motion */
  @keyframes hover{0%,100%{transform:translateY(0);}50%{transform:translateY(-7px);}}
  @keyframes breathe{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-2px) scale(1.025);}}
  .sprite.float{animation:hover 2.6s ease-in-out infinite;}
  .sprite.ground{animation:breathe 3.4s ease-in-out infinite;}
  .sprite{transform-origin:50% 90%;}
  /* enemy hit */
  @keyframes ehit{0%{transform:translateX(0);}18%{transform:translateX(-7px);}38%{transform:translateX(6px);}58%{transform:translateX(-4px);}78%{transform:translateX(3px);}100%{transform:translateX(0);}}
  .enemy.hit{animation:ehit .34s ease-out;}
  @keyframes eflash{0%,100%{filter:drop-shadow(0 3px 5px rgba(0,0,0,.5));}30%{filter:brightness(2.6) drop-shadow(0 0 12px #ff5c72);}}
  .enemy.hit .sprite{animation:eflash .34s ease-out, hover 2.6s ease-in-out infinite;}
  .enemy.hit .sprite.ground{animation:eflash .34s ease-out, breathe 3.4s ease-in-out infinite;}
  /* enemy attack lunge */
  @keyframes elunge{0%{transform:translateY(0);}32%{transform:translateY(15px) scale(1.05);}100%{transform:translateY(0);}}
  .enemy.lunge{animation:elunge .42s ease-out;}
  /* enemy death */
  @keyframes crumble{0%{opacity:1; transform:translateY(0) rotate(0) scale(1);}100%{opacity:.16; transform:translateY(12px) rotate(-7deg) scale(.88);}}
  .enemy.dying{animation:crumble .6s ease-in forwards;}
  /* screen shake + hurt vignette */
  @keyframes cshake{0%{transform:translate(0,0);}20%{transform:translate(-6px,3px);}40%{transform:translate(6px,-2px);}60%{transform:translate(-4px,-3px);}80%{transform:translate(3px,3px);}100%{transform:translate(0,0);}}
  #combat.shake{animation:cshake .42s ease-in-out;}
  #hurt-flash{position:fixed; inset:0; pointer-events:none; z-index:90; opacity:0; background:radial-gradient(circle at 50% 55%, transparent 38%, rgba(255,40,60,.5));}
  #hurt-flash.on{animation:hurtf .42s ease-out;}
  @keyframes hurtf{0%{opacity:0;}22%{opacity:1;}100%{opacity:0;}}
  /* cast ring flare */
  .ring-flare{position:fixed; width:22px; height:22px; margin:-11px 0 0 -11px; border-radius:50%; border:3px solid var(--rc,#f0c968); pointer-events:none; z-index:54; animation:ringf .55s ease-out forwards;}
  @keyframes ringf{0%{opacity:.9; transform:scale(.4);}100%{opacity:0; transform:scale(2.7);}}
  /* reaction label pop */
  .react-pop{position:fixed; transform:translate(-50%,0); pointer-events:none; z-index:56; color:var(--gold); font-family:'Georgia',serif; font-weight:bold; font-size:16px; text-shadow:0 0 9px #ff7a2f, 0 1px 2px #000; letter-spacing:.06em; white-space:nowrap; animation:reactp .95s ease-out forwards;}
  @keyframes reactp{0%{opacity:0; transform:translate(-50%,8px) scale(.7);}25%{opacity:1; transform:translate(-50%,-6px) scale(1.12);}100%{opacity:0; transform:translate(-50%,-34px) scale(1);}}
  /* block shimmer on hero panel */
  .hero-panel.shimmer{animation:hpsh .55s ease-out;}
  @keyframes hpsh{0%,100%{box-shadow:none; border-color:var(--edge);}50%{box-shadow:0 0 20px rgba(120,190,255,.6); border-color:#8fd0ff;}}
  /* attack intent pulse */
  .intent.atk{animation:ipulse 1.5s ease-in-out infinite;}
  @keyframes ipulse{0%,100%{box-shadow:0 0 0 rgba(255,92,114,0);}50%{box-shadow:0 0 11px rgba(255,92,114,.65);}}
  /* new-turn energy orb pop */
  @keyframes orbpop{0%{transform:scale(.2); opacity:0;}70%{transform:scale(1.2);}100%{transform:scale(1); opacity:1;}}
  .orb.on.fresh{animation:orbpop .3s ease-out;}
  /* cast projectile — outer handles travel, inner handles shape/spin */
  .projectile{position:fixed; pointer-events:none; z-index:57; transition:transform .185s cubic-bezier(.5,0,.9,.6);}
  .proj-core{position:absolute;}
  .proj-fire{width:16px; height:16px; margin:-8px 0 0 -8px; border-radius:50%;
    background:radial-gradient(circle at 50% 45%, #fff, #ff9a44 45%, #ff7a2f 65%, #a5320c); box-shadow:0 0 16px 4px #ff7a2f; transform:rotate(var(--ang));}
  .proj-fire::before{content:''; position:absolute; left:-22px; top:4px; width:24px; height:8px; border-radius:50%;
    background:linear-gradient(270deg, rgba(255,150,60,.85), transparent);}
  .proj-ice{width:22px; height:12px; margin:-6px 0 0 -11px; background:linear-gradient(90deg,#eafcff,#5fd4ff);
    clip-path:polygon(0 50%,58% 0,100% 50%,58% 100%); box-shadow:0 0 12px #5fd4ff; transform:rotate(var(--ang));}
  .proj-storm{width:24px; height:16px; margin:-8px 0 0 -12px; background:#efe0ff;
    clip-path:polygon(0 42%,42% 42%,26% 4%,66% 46%,44% 46%,60% 96%,24% 54%,44% 54%); box-shadow:0 0 12px #c07bff;
    transform:rotate(var(--ang)); animation:pflick .1s steps(2,end) infinite;}
  @keyframes pflick{0%,100%{opacity:1;}50%{opacity:.5;}}
  .proj-earth{width:17px; height:17px; margin:-8.5px 0 0 -8.5px;
    background:radial-gradient(circle at 38% 34%, #e6c088, #8a6a3a 68%, #55401e);
    clip-path:polygon(22% 0,72% 6%,100% 42%,84% 86%,40% 100%,4% 62%); box-shadow:0 0 9px #6a4a20; animation:ptumble .32s linear infinite;}
  @keyframes ptumble{to{transform:rotate(360deg);}}
  /* ambient embers in the tower */
  .ember{position:absolute; bottom:0; border-radius:50%; background:radial-gradient(circle,#ffd89a,#ff7a2f); opacity:0; pointer-events:none; animation:emberRise linear infinite;}
  @keyframes emberRise{0%{transform:translateY(0) translateX(0); opacity:0;}12%{opacity:.7;}86%{opacity:.35;}100%{transform:translateY(-440px) translateX(var(--drift,0)); opacity:0;}}
  /* hero portrait idle */
  .hero-panel .heroart{animation:heroBob 3.6s ease-in-out infinite, heroGlow 2.3s ease-in-out infinite;}
  @keyframes heroBob{0%,100%{transform:translateY(0);}50%{transform:translateY(-3px);}}
  @keyframes heroGlow{0%,100%{filter:drop-shadow(0 0 12px rgba(255,122,47,.45));}50%{filter:drop-shadow(0 0 19px rgba(255,150,60,.72));}}
  .hero-hint .heroart{animation:heroGlow 2.3s ease-in-out infinite;}
  /* player HP bar: hit flash + low warning */
  .bar.hphit{animation:hphit .42s ease-out;}
  @keyframes hphit{0%,100%{box-shadow:none;}30%{box-shadow:0 0 13px 2px #ff5c72;}}
  .bar.low .hpfill{animation:lowpulse 1s ease-in-out infinite;}
  @keyframes lowpulse{0%,100%{filter:brightness(1);}50%{filter:brightness(1.55) drop-shadow(0 0 6px #ff2d44);}}
  /* pulsing target reticle (on ::after so it doesn't steal the enemy's hit/lunge animation) */
  .enemy.targeted::after{content:''; position:absolute; inset:-4px; border-radius:16px; border:2px solid var(--gold); pointer-events:none; animation:tgtpulse 1.4s ease-in-out infinite;}
  @keyframes tgtpulse{0%,100%{box-shadow:0 0 9px rgba(240,201,104,.3); opacity:.65;}50%{box-shadow:0 0 20px rgba(240,201,104,.6); opacity:1;}}
  /* hit-stop impact punch */
  #app.punch{animation:punch .18s ease-out;}
  #app.punch-lg{animation:punchLg .26s ease-out;}
  @keyframes punch{0%{transform:scale(1);}45%{transform:scale(1.02);}100%{transform:scale(1);}}
  @keyframes punchLg{0%{transform:scale(1);}12%{transform:scale(1.045);}45%{transform:scale(.992);}100%{transform:scale(1);}}
  /* screen wipe transition */
  .wipe{position:fixed; inset:0; z-index:120; pointer-events:none; transform:translateX(-105%);
    background:linear-gradient(115deg, transparent 0%, rgba(27,19,11,.9) 22%, #2a1608 46%, #1b130b 54%, rgba(27,19,11,.9) 78%, transparent 100%);
    animation:wipe .76s cubic-bezier(.7,0,.3,1) forwards;}
  .wipe::after{content:''; position:absolute; top:0; bottom:0; left:46%; width:8%;
    background:radial-gradient(ellipse at center, rgba(255,140,60,.5), transparent 70%);}
  @keyframes wipe{0%{transform:translateX(-105%);}100%{transform:translateX(105%);}}
  /* victory flash */
  .victory-flash{position:fixed; inset:0; z-index:118; pointer-events:none; display:flex; align-items:center; justify-content:center;}
  .victory-flash .vf-rays{position:absolute; width:600px; height:600px; max-width:120vw; max-height:120vh;
    background:radial-gradient(circle, rgba(255,180,70,.28), transparent 55%);
    background-image:conic-gradient(from 0deg, rgba(255,190,90,.22) 0 8deg, transparent 8deg 30deg, rgba(255,190,90,.22) 30deg 38deg, transparent 38deg 60deg, rgba(255,190,90,.22) 60deg 68deg, transparent 68deg 90deg, rgba(255,190,90,.22) 90deg 98deg, transparent 98deg 120deg, rgba(255,190,90,.22) 120deg 128deg, transparent 128deg 150deg, rgba(255,190,90,.22) 150deg 158deg, transparent 158deg 180deg, rgba(255,190,90,.22) 180deg 188deg, transparent 188deg 210deg, rgba(255,190,90,.22) 210deg 218deg, transparent 218deg 240deg, rgba(255,190,90,.22) 240deg 248deg, transparent 248deg 270deg, rgba(255,190,90,.22) 270deg 278deg, transparent 278deg 300deg, rgba(255,190,90,.22) 300deg 308deg, transparent 308deg 330deg, rgba(255,190,90,.22) 330deg 338deg, transparent 338deg 360deg);
    animation:vfrays 1.05s ease-out forwards;}
  @keyframes vfrays{0%{opacity:0; transform:scale(.5) rotate(0);}30%{opacity:1;}100%{opacity:0; transform:scale(1.15) rotate(28deg);}}
  .victory-flash .vf-text{position:relative; font-family:'Georgia',serif; font-size:58px; font-weight:bold; color:var(--gold);
    letter-spacing:.14em; text-shadow:0 0 24px rgba(255,140,50,.8), 0 3px 6px #000; animation:vftext 1.05s cubic-bezier(.2,1.4,.4,1) forwards;}
  @keyframes vftext{0%{opacity:0; transform:scale(.5);}25%{opacity:1; transform:scale(1.08);}70%{opacity:1; transform:scale(1);}100%{opacity:0; transform:scale(1.02);}}

  /* ---------- CLASS SELECT ---------- */
  #classselect{text-align:center; padding:26px 0;}
  #classselect h2{color:var(--gold); font-size:34px; margin-bottom:4px;}
  #classselect .cs-sub{color:var(--dim); font-size:14px; margin-bottom:26px; letter-spacing:.05em;}
  .class-cards{display:flex; gap:22px; justify-content:center; flex-wrap:wrap; margin-bottom:24px;}
  .class-card{width:280px; background:linear-gradient(180deg,var(--panel2),var(--panel)); border:2px solid var(--edge); border-radius:18px;
    padding:20px 18px; transition:.18s; position:relative; text-align:center;}
  .class-card.selectable{cursor:pointer;}
  .class-card.selectable:hover{transform:translateY(-5px); border-color:var(--gold); box-shadow:0 8px 26px rgba(0,0,0,.5), 0 0 22px rgba(240,201,104,.3);}
  .class-card.locked{opacity:.55; filter:grayscale(.5);}
  .class-card .cc-art{width:120px; height:144px; margin:0 auto; filter:drop-shadow(0 0 16px rgba(255,122,47,.45));}
  .class-card.locked .cc-art{filter:grayscale(1) brightness(.6);}
  .class-card h3{font-size:22px; color:var(--gold); margin:8px 0 2px;}
  .class-card .cc-tag{font-size:12.5px; color:var(--dim); font-style:italic; margin-bottom:12px; min-height:32px;}
  .class-card .cc-line{font-size:12.5px; color:var(--txt); text-align:left; margin:7px 4px; line-height:1.4; display:flex; gap:8px;}
  .class-card .cc-line b{color:var(--ember);}
  .class-card .cc-key{flex:0 0 auto; width:60px; color:var(--gold); font-weight:bold; text-align:right;}
  .class-card .cc-locktag{position:absolute; top:12px; right:12px; background:#160f08; border:1px solid var(--edge); color:var(--dim);
    font-size:10px; letter-spacing:.08em; text-transform:uppercase; padding:3px 9px; border-radius:10px;}
  .class-card .cc-select{margin-top:14px; display:inline-block; background:linear-gradient(180deg,#c1531b,#7c3410); border:1px solid #ff8a44;
    color:#fff; padding:9px 26px; border-radius:10px; font-size:15px;}

  /* ---------- OVERLAYS ---------- */
  .overlay{position:fixed; inset:0; background:rgba(8,5,2,.84); display:flex; align-items:center; justify-content:center; z-index:100; padding:20px;}
  .modal{background:linear-gradient(180deg,var(--panel2),var(--panel)); border:1px solid var(--gold); border-radius:18px; padding:28px; max-width:660px; width:100%; text-align:center; box-shadow:0 0 50px rgba(0,0,0,.75);}
  .modal h2{color:var(--gold); font-size:28px; margin-bottom:6px;}
  .modal p{color:var(--dim); margin-bottom:18px;}
  .reward-runes{display:flex; gap:16px; justify-content:center; flex-wrap:wrap; margin-bottom:20px;}
  .rcard{width:134px; background:var(--panel); border:2px solid var(--edge); border-radius:14px; padding:14px 10px; cursor:pointer; transition:.15s;}
  .rcard:hover{transform:translateY(-4px); border-color:var(--gold); box-shadow:0 0 16px rgba(240,201,104,.4);}
  .rcard .glyph{font-size:40px;} .rcard .glyph .sigil{filter:drop-shadow(0 0 8px currentColor);}
  .rcard.fire{border-color:var(--fire);} .rcard.ice{border-color:var(--ice);}
  .rcard.storm{border-color:var(--storm);} .rcard.earth{border-color:var(--earth);}
  .rcard h3{font-size:15px; margin:6px 0 3px;}
  .rcard .rc-elem{font-size:11px; text-transform:uppercase; letter-spacing:.1em; color:var(--dim);}
  .rcard .rc-desc{font-size:11px; color:var(--txt); margin-top:6px; line-height:1.35;}
  .rcard .rc-cost{font-size:11px; color:var(--gold); margin-top:5px;}
  .tip{font-size:12px; color:var(--dim); margin-top:8px;}
  .center{text-align:center;}
</style>
</head>
<body>
<div id="app">
  <!-- TITLE -->
  <div id="title" class="screen">
    <h1 class="glow">SIGILSPIRE</h1>
    <div class="sub">Ascend the Rune Tower</div>
    <div class="tag">A deterministic tower-climb where your power is a <b>3×3 board of runes</b>. Touching runes react — <b>arrange the board and it becomes your build.</b></div>
    <div class="hero-hint">
      <div class="heroart" id="title-hero"></div>
      <div class="ht"><b>The Flame Knight</b><span>Fire reactions forge <b>Ember Aura</b> (Block). Once per fight, <b>Flame Brand</b> ignites the whole board.</span></div>
    </div>
    <button class="btn primary" style="font-size:18px; padding:14px 34px;" onclick="showClassSelect()">Begin the Climb</button>
    <div class="reactguide" id="title-guide" style="max-width:540px; margin:26px auto 0;"></div>
  </div>

  <!-- CLASS SELECT -->
  <div id="classselect" class="screen" style="display:none;">
    <h2 class="glow">Choose Your Aspirant</h2>
    <div class="cs-sub">The tower tests all who climb. Which discipline is yours?</div>
    <div class="class-cards" id="class-cards"></div>
    <button class="btn" onclick="show('title')">← Back</button>
  </div>

  <!-- MAP -->
  <div id="map-wrap" class="screen" style="display:none;">
    <div class="map-header">
      <h2 class="glow">The Ascent</h2>
      <div style="display:flex; gap:10px; align-items:center;">
        <span class="hp-pill">❤️ <b id="map-hp">80</b>/<span id="map-maxhp">80</span></span>
        <button class="btn" onclick="openBoardEditor()">⚙ Arrange Board</button>
      </div>
    </div>
    <div class="map" id="map"></div>
    <div class="center" style="margin-top:10px; color:var(--dim); font-size:13px;">Choose your next path upward.</div>
  </div>

  <!-- COMBAT -->
  <div id="combat" class="screen">
    <div class="tower-bg"></div>
    <div class="topbar">
      <div class="stat"><span class="ic" id="ic-heart"></span>
        <div class="bar"><span class="hpfill" id="php-fill" style="width:100%"></span><span class="lab" id="php-lab">80/80</span></div>
      </div>
      <span class="block-badge" id="pblock"></span>
      <div class="stat" style="margin-left:auto;"><span class="ic" id="ic-energy"></span><div class="energy-orbs" id="orbs"></div></div>
      <div class="stat"><span class="ic" id="ic-floor"></span> Floor <b id="floornum">1</b></div>
    </div>

    <div class="enemies" id="enemies"></div>

    <div class="arena-mid">
      <div class="hero-panel">
        <div class="heroart" id="combat-hero"></div>
        <div class="hname">Flame Knight</div>
        <button class="brand-btn" id="brand-btn" onclick="flameBrand()">🔥 Flame Brand<small>ignite the board</small></button>
        <div class="aura-note"><b>Ember Aura:</b> Fire reactions grant Block.</div>
      </div>
      <div class="board-wrap">
        <div class="board" id="board"></div>
        <div class="hint" id="board-hint">Click a glowing rune to cast it.</div>
      </div>
      <div class="combat-right">
        <button class="endturn" onclick="endTurn()"><span id="ic-endturn"></span> End Turn</button>
        <div class="hint">Enemies show their next move. Plan around it.</div>
      </div>
    </div>

    <div id="log"></div>
  </div>
</div>
<div id="overlay-mount"></div>

<script>
/* =====================================================================
   SIGILSPIRE — deterministic rune-socketing tower climb
   Flame Knight starter · molten-arcane visual pass
   ===================================================================== */

/* ---------------- SVG ASSET LIBRARY ---------------- */
const SIGIL_SVG = {
  fire:`<svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="none" stroke="currentColor" stroke-width="1.3" opacity=".4"/><g stroke="currentColor" stroke-width="1.3" opacity=".55"><line x1="24" y1="3" x2="24" y2="8"/><line x1="24" y1="40" x2="24" y2="45"/><line x1="3" y1="24" x2="8" y2="24"/><line x1="40" y1="24" x2="45" y2="24"/></g><path d="M24 12 C31 19 31 25 26.5 29 C28 25 24.5 23 24 20 C20.5 25 18 27 20.5 32 C15.5 28 16 18 24 12 Z" fill="currentColor"/></svg>`,
  ice:`<svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="none" stroke="currentColor" stroke-width="1.3" opacity=".4"/><g stroke="currentColor" stroke-width="1.3" opacity=".55"><line x1="24" y1="3" x2="24" y2="8"/><line x1="24" y1="40" x2="24" y2="45"/><line x1="3" y1="24" x2="8" y2="24"/><line x1="40" y1="24" x2="45" y2="24"/></g><g stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"><line x1="24" y1="10" x2="24" y2="38"/><line x1="11.9" y1="17" x2="36.1" y2="31"/><line x1="36.1" y1="17" x2="11.9" y2="31"/><line x1="24" y1="14" x2="20.5" y2="17"/><line x1="24" y1="14" x2="27.5" y2="17"/><line x1="24" y1="34" x2="20.5" y2="31"/><line x1="24" y1="34" x2="27.5" y2="31"/></g></svg>`,
  storm:`<svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="none" stroke="currentColor" stroke-width="1.3" opacity=".4"/><g stroke="currentColor" stroke-width="1.3" opacity=".55"><line x1="24" y1="3" x2="24" y2="8"/><line x1="24" y1="40" x2="24" y2="45"/><line x1="3" y1="24" x2="8" y2="24"/><line x1="40" y1="24" x2="45" y2="24"/></g><path d="M28 11 L16 26 L23 26 L20 37 L33 21 L26 21 Z" fill="currentColor"/></svg>`,
  earth:`<svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="none" stroke="currentColor" stroke-width="1.3" opacity=".4"/><g stroke="currentColor" stroke-width="1.3" opacity=".55"><line x1="24" y1="3" x2="24" y2="8"/><line x1="24" y1="40" x2="24" y2="45"/><line x1="3" y1="24" x2="8" y2="24"/><line x1="40" y1="24" x2="45" y2="24"/></g><path d="M12 34 L21 18 L27 27 L30.5 22 L36 34 Z" fill="currentColor"/><line x1="11" y1="34.5" x2="37" y2="34.5" stroke="currentColor" stroke-width="2"/></svg>`,
};
function sigil(elem){ return `<span class="sigil ${elem}">${SIGIL_SVG[elem]}</span>`; }

const UI_ICON = {
  heart:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21 C4 15 3 9 6.5 6 C9 4 11 5.5 12 7.5 C13 5.5 15 4 17.5 6 C21 9 20 15 12 21 Z"/></svg>`,
  energy:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2 L5 13 L11 13 L9 22 L19 9 L13 9 Z"/></svg>`,
  floor:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 21 V8 L9 8 V5 L12 3 L15 5 V8 L19 8 V21 Z" opacity=".9"/><rect x="10.5" y="13" width="3" height="8" fill="#0d0906"/></svg>`,
  sword:`<svg viewBox="0 0 24 24"><path d="M13.5 3 L21 3 L21 10.5 L11 20.5 L7.5 17 L17.5 7 Z" fill="currentColor"/><path d="M3 16.5 L7.5 21" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"/></svg>`,
  shield:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3 L20 6 V12 C20 17 16.5 20 12 21.5 C7.5 20 4 17 4 12 V6 Z"/></svg>`,
  buff:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 13 L12 7 L18 13"/><path d="M6 18 L12 12 L18 18"/></svg>`,
  refresh:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M20 11 A8 8 0 1 0 19 15"/><path d="M20 5 V11 H14"/></svg>`,
};

const NODE_ICON = {
  combat:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 3 L11 8 L8 11 L3 6 Z"/><path d="M18 3 L21 6 L11 16 L8 13 Z"/><path d="M3 18 L6 21 M18 18 L21 21" stroke="currentColor" stroke-width="2"/></svg>`,
  elite:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 C7 2 4 6 4 11 C4 13 5 15 5 15 L4 21 L9 19 C10 19.5 11 20 12 20 C13 20 14 19.5 15 19 L20 21 L19 15 C19 15 20 13 20 11 C20 6 17 2 12 2 Z"/><circle cx="9" cy="10" r="1.6" fill="#0d0906"/><circle cx="15" cy="10" r="1.6" fill="#0d0906"/></svg>`,
  rest:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21 C7 18 6 13 9 10 C9 12 10 12.5 11 12 C9 8 12 5 12 3 C14 6 18 8 18 13 C18 17 15 20 12 21 Z"/></svg>`,
  treasure:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L20 8 L12 22 L4 8 Z"/><path d="M12 2 L12 22 M4 8 L20 8" stroke="#0d0906" stroke-width="1.2" opacity=".5"/></svg>`,
  boss:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 8 L7 4 L9 7 L12 3 L15 7 L17 4 L20 8 L18 18 L6 18 Z"/><circle cx="9.5" cy="12" r="1.6" fill="#0d0906"/><circle cx="14.5" cy="12" r="1.6" fill="#0d0906"/></svg>`,
};

const HERO_FLAMEKNIGHT = `<svg viewBox="0 0 100 120" class="hk">
  <defs>
    <linearGradient id="steel" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#9296a6"/><stop offset="1" stop-color="#3c3d4a"/></linearGradient>
    <radialGradient id="emberG" cx="50%" cy="45%" r="65%"><stop offset="0" stop-color="#ffe6a0"/><stop offset="55%" stop-color="#ff7a2f"/><stop offset="100%" stop-color="#a5320c"/></radialGradient>
  </defs>
  <path d="M50 4 C58 15 55 24 62 31 C60 20 52 19 50 10 C48 19 40 20 38 31 C45 24 42 15 50 4 Z" fill="url(#emberG)"/>
  <path d="M37 20 C33 29 37 33 35 40 C41 34 39 27 37 20 Z" fill="url(#emberG)" opacity=".85"/>
  <path d="M63 20 C67 29 63 33 65 40 C59 34 61 27 63 20 Z" fill="url(#emberG)" opacity=".85"/>
  <path d="M30 42 C30 27 70 27 70 46 L70 66 C70 79 61 88 50 88 C39 88 30 79 30 66 Z" fill="url(#steel)" stroke="#23242e" stroke-width="1.5"/>
  <path d="M50 42 L50 66" stroke="#23242e" stroke-width="2"/>
  <path d="M38 53 L62 53 L60 61 L40 61 Z" fill="#140d0a"/>
  <path d="M41 56.5 L59 56.5" stroke="url(#emberG)" stroke-width="3.4" stroke-linecap="round"/>
  <path d="M18 104 C18 87 34 82 41 86 L45 94 L55 94 L59 86 C66 82 82 87 82 104 Z" fill="url(#steel)" stroke="#23242e" stroke-width="1.5"/>
  <path d="M43 88 L57 88 L53 99 L47 99 Z" fill="#43444f"/>
  <circle cx="28" cy="95" r="6" fill="url(#emberG)"/><circle cx="72" cy="95" r="6" fill="url(#emberG)"/>
</svg>`;

const HERO_MAGE = `<svg viewBox="0 0 100 120" class="hk">
  <defs><linearGradient id="mrobe" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#4a3d78"/><stop offset="1" stop-color="#241a44"/></linearGradient></defs>
  <path d="M50 8 L60 22 L40 22 Z" fill="#5a4a90"/>
  <circle cx="50" cy="16" r="4" fill="#c07bff"/>
  <path d="M34 40 C34 26 66 26 66 40 L70 50 C64 54 36 54 30 50 Z" fill="url(#mrobe)"/>
  <path d="M40 44 L46 46 L44 51 Z M60 44 L54 46 L56 51 Z" fill="#c07bff" opacity=".85"/>
  <path d="M22 106 C22 84 34 60 50 58 C66 60 78 84 78 106 Z" fill="url(#mrobe)"/>
  <path d="M50 58 L50 106" stroke="#1a1233" stroke-width="1.5" opacity=".6"/>
  <circle cx="50" cy="78" r="5" fill="#c07bff" opacity=".7"/>
</svg>`;

const CLASSES = {
  flameknight:{ name:'Flame Knight', art:HERO_FLAMEKNIGHT, locked:false,
    tagline:'A tower-sworn knight whose armor runs with living fire.',
    lines:[['Passive','<b>Ember Aura</b> — triggering a Fire reaction grants +3 Block.'],['Active','<b>Flame Brand</b> — once per fight, ignite the whole board.'],['Style','Durable bruiser. Fire wants to touch everything.']] },
  mage:{ name:'Arcane Mage', art:HERO_MAGE, locked:true,
    tagline:'A channeler of raw reaction. Fragile, ferocious.',
    lines:[['Passive','<b>Resonance</b> — stacking power per distinct reaction.'],['Active','<b>Overchannel</b> — spend HP for a burst of energy.'],['Style','Glass-cannon combo caster.']] },
};

const CREATURE = {
  wisp:`<svg viewBox="0 0 100 100"><defs><radialGradient id="wg" cx="50%" cy="34%" r="72%"><stop offset="0" stop-color="#ede0ff"/><stop offset="58%" stop-color="#9a7ad0"/><stop offset="100%" stop-color="#452c68"/></radialGradient></defs><path d="M50 12 C70 12 78 30 78 52 L78 84 C78 88 74 88 72 84 L65 74 L58 85 C56 88 52 88 51 85 L50 80 L49 85 C48 88 44 88 42 85 L35 74 L28 84 C26 88 22 88 22 84 L22 52 C22 30 30 12 50 12 Z" fill="url(#wg)" opacity=".93"/><circle cx="41" cy="46" r="5.5" fill="#1a1030"/><circle cx="59" cy="46" r="5.5" fill="#1a1030"/><circle cx="42.5" cy="44.5" r="2" fill="#fff"/><circle cx="60.5" cy="44.5" r="2" fill="#fff"/></svg>`,
  bat:`<svg viewBox="0 0 100 100"><path d="M50 42 C46 35 40 34 38 39 C33 30 19 28 7 35 C18 37 20 45 30 47 C21 51 19 59 26 63 C30 56 40 53 46 57 L50 66 L54 57 C60 53 70 56 74 63 C81 59 79 51 70 47 C80 45 82 37 93 35 C81 28 67 30 62 39 C60 34 54 35 50 42 Z" fill="#2c2242"/><path d="M43 41 L46 32 L49 41 Z M51 41 L54 32 L57 41 Z" fill="#2c2242"/><circle cx="45" cy="48" r="2.6" fill="#c07bff"/><circle cx="55" cy="48" r="2.6" fill="#c07bff"/></svg>`,
  gargoyle:`<svg viewBox="0 0 100 100"><defs><linearGradient id="gg" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#8f8a78"/><stop offset="1" stop-color="#494740"/></linearGradient></defs><path d="M22 82 L20 52 C11 48 9 35 17 30 C15 40 23 42 27 40 L35 30 L31 19 L41 26 C46 22 54 22 59 26 L69 19 L65 30 L73 40 C77 42 85 40 83 30 C91 35 89 48 80 52 L78 82 Z" fill="url(#gg)"/><path d="M37 30 L34 17 L41 27 Z M63 30 L66 17 L59 27 Z" fill="#494740"/><circle cx="42" cy="41" r="3.2" fill="#ffb14d"/><circle cx="58" cy="41" r="3.2" fill="#ffb14d"/><path d="M41 51 L59 51 L55 59 L45 59 Z" fill="#33322b"/></svg>`,
  sentry:`<svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="34" fill="none" stroke="#5fd4ff" stroke-width="1.5" opacity=".5" stroke-dasharray="4 6"/><circle cx="50" cy="50" r="26" fill="#152740" stroke="#5fd4ff" stroke-width="2"/><ellipse cx="50" cy="50" rx="19" ry="12" fill="#0a1424"/><circle cx="50" cy="50" r="7.5" fill="#5fd4ff"/><circle cx="50" cy="50" r="3" fill="#fff"/><path d="M18 30 L25 37 M82 30 L75 37 M18 70 L25 63 M82 70 L75 63" stroke="#c07bff" stroke-width="2.4"/></svg>`,
  golem:`<svg viewBox="0 0 100 100"><defs><linearGradient id="glm" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#70614c"/><stop offset="1" stop-color="#3b3226"/></linearGradient></defs><rect x="31" y="14" width="38" height="28" rx="5" fill="url(#glm)"/><rect x="20" y="42" width="60" height="42" rx="7" fill="url(#glm)"/><rect x="8" y="46" width="15" height="36" rx="5" fill="url(#glm)"/><rect x="77" y="46" width="15" height="36" rx="5" fill="url(#glm)"/><path d="M40 20 L46 28 L42 36 M60 18 L56 26 L62 34 M34 54 L50 62 L44 76 M66 52 L58 68" stroke="#ff7a2f" stroke-width="2.6" fill="none" opacity=".92"/><circle cx="42" cy="28" r="3.4" fill="#ffca6a"/><circle cx="58" cy="28" r="3.4" fill="#ffca6a"/></svg>`,
  warden:`<svg viewBox="0 0 100 100"><defs><linearGradient id="wd" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#872330"/><stop offset="1" stop-color="#2a0d12"/></linearGradient></defs><path d="M30 30 L21 6 L39 22 M70 30 L79 6 L61 22 M50 20 L43 4 L50 1 L57 4 Z" fill="#e8c66a"/><path d="M29 32 C29 18 71 18 71 32 L73 48 C73 62 61 68 50 68 C39 68 27 62 27 48 Z" fill="url(#wd)" stroke="#e8c66a" stroke-width="1.6"/><path d="M23 94 L28 58 C34 66 66 66 72 58 L77 94 Z" fill="url(#wd)" stroke="#e8c66a" stroke-width="1.6"/><path d="M37 45 L47 42 L44 49 Z M63 45 L53 42 L56 49 Z" fill="#ff5468"/><circle cx="42" cy="45.5" r="2" fill="#fff"/><circle cx="58" cy="45.5" r="2" fill="#fff"/><path d="M42 56 L50 59 L58 56" stroke="#e8c66a" stroke-width="2" fill="none"/></svg>`,
};

/* ---------------- DATA ---------------- */
const ELEM = { fire:{}, ice:{}, storm:{}, earth:{} };
const ELEMCOLOR = {fire:'#ff7a2f', ice:'#5fd4ff', storm:'#c07bff', earth:'#d19a52'};
const FLOATERS = new Set(['wisp','bat','sentry']);

const RUNES = {
  emberbolt:  {name:'Emberbolt',  elem:'fire',  cost:1, kind:'attack', val:6,  desc:'Deal 6 damage.'},
  frostguard: {name:'Frostward',  elem:'ice',   cost:1, kind:'block',  val:6,  desc:'Gain 6 Block.'},
  sparkarc:   {name:'Sparkarc',   elem:'storm', cost:1, kind:'attack', val:4,  desc:'Deal 4 damage.'},
  stoneskin:  {name:'Stoneskin',  elem:'earth', cost:1, kind:'block',  val:5,  desc:'Gain 5 Block.'},
  emberkiss:  {name:'Emberkiss',  elem:'fire',  cost:1, kind:'drain',  val:5,  desc:'Deal 5, heal 3.'},
  cinderlance:{name:'Cinderlance',elem:'fire',  cost:2, kind:'attack', val:13, desc:'Deal 13 damage.'},
  pyre:       {name:'Pyre',       elem:'fire',  cost:1, kind:'aoe',    val:5,  desc:'Deal 5 to ALL foes.'},
  glacier:    {name:'Glacier',    elem:'ice',   cost:2, kind:'block',  val:13, desc:'Gain 13 Block.'},
  hailshard:  {name:'Hailshard',  elem:'ice',   cost:1, kind:'guardstrike', val:4, blk:4, desc:'Deal 4 & gain 4 Block.'},
  thunderclap:{name:'Thunderclap',elem:'storm', cost:2, kind:'aoe',    val:7,  desc:'Deal 7 to ALL foes.'},
  chainbolt:  {name:'Chainbolt',  elem:'storm', cost:1, kind:'attack', val:5,  desc:'Deal 5 damage.'},
  boulder:    {name:'Boulder',    elem:'earth', cost:2, kind:'guardstrike', val:9, blk:5, desc:'Deal 9 & gain 5 Block.'},
  bulwark:    {name:'Bulwark',    elem:'earth', cost:1, kind:'block',  val:8,  desc:'Gain 8 Block.'},
  voltcore:   {name:'Voltcore',   elem:'storm', cost:0, kind:'attack', val:2,  desc:'Deal 2. Costs nothing.'},
  frostpike:  {name:'Frostpike',  elem:'ice',   cost:1, kind:'attack', val:6,  desc:'Deal 6 damage.'},
};
const DRAFT_POOL = ['cinderlance','pyre','glacier','hailshard','thunderclap','chainbolt','boulder','bulwark','emberkiss','voltcore','frostpike'];

const ENEMIES = {
  wisp:   {name:'Tower Wisp', hp:20, pattern:[{t:'atk',v:6},{t:'atk',v:6},{t:'def',v:5}]},
  bat:    {name:'Gloom Bat',  hp:14, pattern:[{t:'atk',v:5},{t:'atk',v:5}]},
  gargoyle:{name:'Gargoyle',  hp:32, pattern:[{t:'def',v:8},{t:'atk',v:11}]},
  sentry: {name:'Rune Sentry',hp:26, pattern:[{t:'atk',v:7},{t:'buff'},{t:'atk',v:9}]},
  golem:  {name:'Rune Golem', hp:58, pattern:[{t:'atk',v:8},{t:'atk',v:8},{t:'atk',v:18}]},
  warden: {name:'Spire Warden',hp:96, pattern:[{t:'atk',v:10},{t:'def',v:10},{t:'atk',v:14},{t:'buff'}]},
};
function rollGroup(type){
  if(type==='elite') return ['golem'];
  if(type==='boss')  return ['warden'];
  const combos=[['wisp'],['wisp','bat'],['gargoyle'],['sentry','bat'],['wisp','wisp'],['sentry']];
  return combos[Math.floor(Math.random()*combos.length)];
}

/* ---------------- STATE ---------------- */
let G=null;
function newGame(){
  return {
    classId:'flameknight',
    maxHp:80, hp:80, maxEnergy:3, energy:3,
    board:[ mk('emberbolt'), mk('sparkarc'), null,
            mk('stoneskin'), mk('emberkiss'), null,
            null, null, null ],
    map:null, floor:0,
    enemies:[], block:0, target:0, playerTurn:true, inCombat:false,
    flameBrandUsed:false, flameBrandActive:false,
  };
}
function mk(id){ return Object.assign({id}, RUNES[id], {used:false}); }

/* ---------------- SCREENS ---------------- */
function show(id){ for(const s of document.querySelectorAll('.screen')) s.style.display='none'; document.getElementById(id).style.display='block'; }
function showClassSelect(){ renderClassSelect(); show('classselect'); }
function renderClassSelect(){
  const wrap=document.getElementById('class-cards');
  wrap.innerHTML=Object.entries(CLASSES).map(([id,c])=>`
    <div class="class-card ${c.locked?'locked':'selectable'}" ${c.locked?'':`onclick="chooseClass('${id}')"`}>
      ${c.locked?'<div class="cc-locktag">Locked</div>':''}
      <div class="cc-art">${c.art}</div>
      <h3>${c.name}</h3>
      <div class="cc-tag">${c.tagline}</div>
      ${c.lines.map(l=>`<div class="cc-line"><span class="cc-key">${l[0]}</span><span>${l[1]}</span></div>`).join('')}
      ${c.locked?'<div class="cc-select" style="opacity:.5; background:#2a2015; border-color:var(--edge);">Unlocks later</div>':'<div class="cc-select">Select</div>'}
    </div>`).join('');
}
function chooseClass(id){ startRun(id); }
function startRun(classId){ G=newGame(); G.classId=classId||'flameknight'; G.map=genMap(); screenWipe(()=>{ show('map-wrap'); renderMap(); }); }

/* ---------------- MAP ---------------- */
function genMap(){
  const ROWS=7, rows=[];
  for(let r=0;r<ROWS;r++){
    let count = r===0?2 : r===ROWS-1?1 : 2+(Math.random()<0.5?1:0);
    const nodes=[];
    for(let c=0;c<count;c++){
      let type;
      if(r===ROWS-1) type='boss';
      else if(r===0) type='combat';
      else{
        const roll=Math.random();
        if(r===3 && c===Math.floor(count/2)) type='elite';
        else if(roll<0.18) type='rest';
        else if(roll<0.32) type='treasure';
        else if(roll<0.45 && r>1) type='elite';
        else type='combat';
      }
      nodes.push({r,c,type,done:false,to:[]});
    }
    rows.push(nodes);
  }
  for(let r=0;r<ROWS-1;r++){
    const cur=rows[r], nxt=rows[r+1];
    cur.forEach((n,i)=>{
      const t=Math.min(nxt.length-1, Math.round(i*(nxt.length-1)/Math.max(1,cur.length-1)));
      n.to.push(t);
      if(Math.random()<0.5){ const alt=Math.max(0,Math.min(nxt.length-1,t+(Math.random()<0.5?-1:1))); if(!n.to.includes(alt)) n.to.push(alt); }
    });
    nxt.forEach((_,j)=>{ if(!cur.some(n=>n.to.includes(j))){ let best=0,bd=99; cur.forEach((n,i)=>{const d=Math.abs(i-j); if(d<bd){bd=d;best=i;}}); cur[best].to.push(j);} });
  }
  return {rows, cur:null};
}
function nodeReachable(n){ const m=G.map; if(m.cur===null) return n.r===0; if(n.r!==m.cur.r+1) return false; return m.cur.to.includes(n.c); }
function renderMap(){
  document.getElementById('map-hp').textContent=Math.max(0,G.hp);
  document.getElementById('map-maxhp').textContent=G.maxHp;
  const LBL={combat:'Fight',elite:'Elite',rest:'Rest',treasure:'Cache',boss:'Warden'};
  let html='';
  [...G.map.rows].reverse().forEach(row=>{
    html+='<div class="map-row">';
    row.forEach(n=>{
      const reach=nodeReachable(n), isCur=G.map.cur===n;
      let cls='node'+(n.type==='boss'?' boss':'');
      if(n.done) cls+=' done'; if(isCur) cls+=' current'; else if(reach) cls+=' reachable';
      html+=`<div class="${cls}" ${reach?`onclick="enterNode(${n.r},${n.c})"`:''}><span class="ni">${NODE_ICON[n.type]}</span><span class="lbl">${LBL[n.type]}</span></div>`;
    });
    html+='</div>';
  });
  document.getElementById('map').innerHTML=html;
}
function enterNode(r,c){
  const n=G.map.rows[r][c]; if(!nodeReachable(n)) return;
  G.map.cur=n; G.floor=r+1;
  if(n.type==='rest') return restNode();
  if(n.type==='treasure') return treasureNode();
  screenWipe(()=>startCombat(n));
}

/* ---------------- COMBAT ---------------- */
function startCombat(node){
  G.inCombat=true;
  G.flameBrandUsed=false; G.flameBrandActive=false;
  const isBoss=node.type==='boss';
  G.enemies=rollGroup(node.type).map(id=>{const t=ENEMIES[id]; return {id,name:t.name,hp:t.hp,maxHp:t.hp,pattern:t.pattern,pi:0,block:0,burn:0,freeze:0,strength:0,intent:null,big:(id==='golem'||id==='warden')};});
  G.target=0; G.block=0;
  computeIntents(); startPlayerTurn(true);
  document.getElementById('floornum').textContent=G.floor;
  show('combat'); logClear();
  log(`Floor ${G.floor}: ${G.enemies.map(e=>e.name).join(' & ')} appear.`);
  buildEnemies();
  renderCombat();
}
function computeIntents(){ for(const e of G.enemies){ if(e.hp<=0){e.intent=null;continue;} const raw=e.pattern[e.pi%e.pattern.length]; let it={...raw}; if(it.t==='atk') it.dmg=it.v+(e.strength||0); e.intent=it; } }
function startPlayerTurn(first){ G.playerTurn=true; G.energy=G.maxEnergy; G.block=0; G.flameBrandActive=false; G._orbFresh=true; for(const r of G.board) if(r) r.used=false; if(!first) log('— Your turn —'); }
function aliveEnemies(){ return G.enemies.filter(e=>e.hp>0); }
function currentTarget(){ if(G.enemies[G.target]&&G.enemies[G.target].hp>0) return G.enemies[G.target]; return aliveEnemies()[0]||null; }

const NEIGHBORS=[[1,3],[0,2,4],[1,5],[0,4,6],[1,3,5,7],[2,4,8],[3,7],[4,6,8],[5,7]];

function castRune(idx){
  if(!G.playerTurn) return;
  const rune=G.board[idx]; if(!rune||rune.used) return;
  if(G.energy<rune.cost){ flashHint('Not enough energy.'); return; }
  const tgt=currentTarget();
  if((rune.kind==='attack'||rune.kind==='drain'||rune.kind==='guardstrike')&&!tgt) return;

  G.energy-=rune.cost; rune.used=true;
  ringFlare(cellAnchor(idx), ELEMCOLOR[rune.elem]);

  const neighElems=NEIGHBORS[idx].map(i=>G.board[i]).filter(Boolean).map(r=>r.elem);
  if(G.flameBrandActive) neighElems.push('fire');
  const sameCount=neighElems.filter(e=>e===rune.elem).length;
  const attune=1+0.4*sameCount;
  const hasNeigh=el=>neighElems.includes(el);

  let reactions=[], dmg=0, blk=0, heal=0, aoe=false;
  if(rune.kind==='attack'){ dmg=Math.round(rune.val*attune); }
  else if(rune.kind==='aoe'){ dmg=Math.round(rune.val*attune); aoe=true; }
  else if(rune.kind==='block'){ blk=Math.round(rune.val*attune); }
  else if(rune.kind==='drain'){ dmg=Math.round(rune.val*attune); heal=3; }
  else if(rune.kind==='guardstrike'){ dmg=Math.round(rune.val*attune); blk=Math.round(rune.blk*attune); }
  if(sameCount>0) reactions.push('Attune ×'+attune.toFixed(1).replace('.0',''));

  let pierce=false, splash=0, burnApply=0, freezeApply=0, shatter=0, fireReaction=false;
  const E=rune.elem;
  if(E==='fire'){
    if(hasNeigh('ice')){ shatter=6; fireReaction=true; reactions.push('Shatter +6'); }
    if(hasNeigh('storm')){ splash=0.5; fireReaction=true; reactions.push('Wildfire'); }
    if(hasNeigh('earth')){ burnApply=3; fireReaction=true; reactions.push('Magma (Burn 3)'); }
  } else if(E==='ice'){
    if(hasNeigh('fire')){ shatter=6; fireReaction=true; reactions.push('Shatter +6'); }
    if(hasNeigh('storm')){ freezeApply=1; reactions.push('Flashfreeze'); }
    if(hasNeigh('earth')){ blk+=4; reactions.push('Permafrost +4'); }
  } else if(E==='storm'){
    if(hasNeigh('fire')){ splash=0.5; fireReaction=true; reactions.push('Wildfire'); }
    if(hasNeigh('ice')){ freezeApply=1; reactions.push('Flashfreeze'); }
    if(hasNeigh('earth')){ pierce=true; dmg+=4; reactions.push('Ground Current +4'); }
  } else if(E==='earth'){
    if(hasNeigh('fire')){ burnApply=3; fireReaction=true; reactions.push('Magma (Burn 3)'); }
    if(hasNeigh('ice')){ blk+=4; reactions.push('Permafrost +4'); }
    if(hasNeigh('storm')){ pierce=true; dmg+=4; reactions.push('Ground Current +4'); }
  }

  // Flame Knight — Ember Aura
  let aura=0;
  if(G.classId==='flameknight' && fireReaction){ aura=3; blk+=aura; }

  if(blk>0){ G.block+=blk; floatText(`+${blk}`, playerAnchor(), '#8fd0ff'); burst(playerAnchor(),'#7fb8ff',5); }
  if(heal>0){ G.hp=Math.min(G.maxHp,G.hp+heal); floatText(`+${heal}`, playerAnchor(), '#79e0a0'); }

  const src=cellAnchor(idx);
  const rColor=ELEMCOLOR[E];
  const bigReact=reactions.some(r=>!r.startsWith('Attune'));
  // impact visual (deferred to projectile arrival)
  const impactVis=(e,amount,col)=>{ if(!e) return; floatText(`-${amount}`, enemyAnchor(e), '#ff7b8f'); burst(enemyAnchor(e), col||rColor, bigReact?9:6); hitEnemy(e); if(e.hp<=0) impactPunch(true); else if(bigReact) impactPunch(false); };
  // subtract state now; show impact on arrival (proj) or immediately (secondary)
  const dealTo=(e,amount,pb,useProj,col)=>{ if(!e||e.hp<=0||amount<=0) return; let rem=amount; if(!pb){const ab=Math.min(e.block,rem); e.block-=ab; rem-=ab;} e.hp-=rem; if(useProj) projectile(src, enemyAnchor(e), E, ()=>impactVis(e,amount,col)); else impactVis(e,amount,col); };

  if(aoe){
    for(const e of aliveEnemies()){ dealTo(e,dmg,pierce,true); if(burnApply)e.burn+=burnApply; if(freezeApply)e.freeze+=freezeApply; if(shatter)dealTo(e,shatter,true,false,'#f0c968'); }
  } else if(dmg>0||shatter>0||burnApply||freezeApply){
    dealTo(tgt,dmg,pierce,true);
    if(shatter) dealTo(tgt,shatter,true,false,'#f0c968');
    if(splash){ for(const e of aliveEnemies()){ if(e!==tgt) dealTo(e,Math.round(dmg*splash),pierce,true);} }
    if(burnApply&&tgt&&tgt.hp>0) tgt.burn+=burnApply;
    if(freezeApply&&tgt&&tgt.hp>0) tgt.freeze+=freezeApply;
  }

  let line=`Cast ${rune.name}`;
  if(reactions.length) line+=` → <span class="react">${reactions.join(', ')}</span>`;
  if(aura) line+=` <span class="aura">Ember Aura +${aura} Block</span>`;
  log(line);

  // reaction label pop
  const named=reactions.filter(r=>!r.startsWith('Attune'));
  if(named.length){ const a = (tgt && !aoe) ? enemyAnchor(tgt) : (aliveEnemies()[0] ? enemyAnchor(aliveEnemies()[0]) : playerAnchor()); reactionText(a, named[0].split(' ')[0].toUpperCase()+'!'); }
  if(blk>0) blockShimmer();

  checkCombatEnd(); renderCombat();
}

function flameBrand(){
  if(!G.inCombat||!G.playerTurn||G.flameBrandUsed) return;
  G.flameBrandUsed=true; G.flameBrandActive=true;
  log(`<span class="aura">Flame Brand! The board ignites — every rune burns this turn.</span>`);
  renderCombat();
  // ignite animation across the freshly-rendered board + particles
  document.querySelectorAll('#board .cell').forEach((c,i)=>{ if(G.board[i]){ c.classList.add('ignited'); const r=c.getBoundingClientRect(); burst({x:r.left+r.width/2,y:r.top+r.height/2},'#ff7a2f',7);} });
}

function endTurn(){ if(!G.playerTurn||!G.inCombat) return; G.playerTurn=false; renderCombat(); setTimeout(enemyPhase,350); }
function enemyPhase(){
  for(const e of G.enemies){
    if(e.hp<=0) continue;
    if(e.burn>0){ e.hp-=e.burn; floatText(`-${e.burn}`, enemyAnchor(e), '#ff9d5c'); burst(enemyAnchor(e),'#ff7a2f',4); hitEnemy(e); e.burn--; }
    if(e.hp<=0) continue;
    if(e.freeze>0){ e.freeze--; log(`${e.name} is frozen!`); continue; }
    const it=e.intent; if(!it) continue;
    if(it.t==='atk'){ lungeEnemy(e); let d=it.dmg; const ab=Math.min(G.block,d); G.block-=ab; d-=ab; G.hp-=d; floatText(d>0?`-${d}`:'block', playerAnchor(), d>0?'#ff5c72':'#8fd0ff'); if(d>0){ shakeScreen(); hurtFlash(); hpBarFlash(); } log(`${e.name} strikes for ${it.dmg}${ab?` (${ab} blocked)`:''}.`); }
    else if(it.t==='def'){ e.block+=it.v; log(`${e.name} braces (+${it.v} Block).`); }
    else if(it.t==='buff'){ e.strength=(e.strength||0)+3; log(`${e.name} empowers itself (+3 Strength).`); }
    e.pi++;
  }
  checkCombatEnd();
  if(!G.inCombat) return;
  if(G.hp<=0){ renderCombat(); return gameOver(); }
  computeIntents(); startPlayerTurn(false); renderCombat();
}
function checkCombatEnd(){ if(G.hp<=0){ G.inCombat=false; return; } if(aliveEnemies().length===0){ G.inCombat=false; setTimeout(winCombat,420); } }

/* ---------------- REWARD / NODES ---------------- */
function winCombat(){
  G.map.cur.done=true;
  if(G.map.cur.type==='boss') return victoryScreen();
  log('Victory!');
  victoryFlash(()=>{
    const pool=[...DRAFT_POOL].sort(()=>Math.random()-0.5).slice(0,3);
    overlay(`<h2>Spoils of the Climb</h2><p>Claim a rune to socket into your board.</p><div class="reward-runes">${pool.map(id=>rcardHTML(id)).join('')}</div><button class="btn" onclick="skipReward()">Skip</button>`);
  });
}
function rcardHTML(id){ const r=RUNES[id]; return `<div class="rcard ${r.elem}" onclick="claimRune('${id}')"><div class="glyph">${sigil(r.elem)}</div><h3>${r.name}</h3><div class="rc-elem">${r.elem}</div><div class="rc-desc">${r.desc}</div><div class="rc-cost">✦ ${r.cost} energy</div></div>`; }
function claimRune(id){ G._pending=mk(id); closeOverlay(); openBoardEditor(true); }
function skipReward(){ closeOverlay(); returnToMap(); }
function treasureNode(){ G.map.cur.done=true; const pool=[...DRAFT_POOL].sort(()=>Math.random()-0.5).slice(0,3); overlay(`<h2>Hidden Cache</h2><p>A rune lies waiting. Take one freely.</p><div class="reward-runes">${pool.map(id=>rcardHTML(id)).join('')}</div><button class="btn" onclick="skipReward()">Leave it</button>`); }
function restNode(){ G.map.cur.done=true; overlay(`<h2>Waystone</h2><p>A moment of calm on the ascent.</p><div style="display:flex; gap:16px; justify-content:center;"><button class="btn gold" onclick="restHeal()">Rest — heal ${Math.round(G.maxHp*0.3)} HP</button><button class="btn" onclick="restArrange()">Attune — arrange board</button></div>`); }
function restHeal(){ G.hp=Math.min(G.maxHp,G.hp+Math.round(G.maxHp*0.3)); closeOverlay(); returnToMap(); }
function restArrange(){ closeOverlay(); openBoardEditor(); }
function returnToMap(){ G.inCombat=false; screenWipe(()=>{ show('map-wrap'); renderMap(); }); }

/* ---------------- BOARD EDITOR ---------------- */
let editorPlacing=false, dragFrom=null;
function openBoardEditor(placing=false){
  editorPlacing=placing;
  const pend=G._pending;
  let pendHTML='';
  if(pend){ pendHTML=`<div style="margin-bottom:14px;"><div style="color:var(--dim); font-size:13px; margin-bottom:8px;">New rune — click an empty cell (or a rune to replace it):</div><div class="rcard ${pend.elem}" style="margin:0 auto; width:134px; cursor:default;"><div class="glyph">${sigil(pend.elem)}</div><h3>${pend.name}</h3><div class="rc-desc">${pend.desc}</div><div class="rc-cost">✦ ${pend.cost}</div></div></div>`; }
  overlay(`<h2>Arrange the Board</h2><p>${pend?'Place your new rune, then drag to optimize adjacencies.':'Drag runes to swap positions. Adjacent elements react.'}</p>${pendHTML}<div class="board" id="editor-board" style="margin:0 auto 16px;"></div><div class="reactguide" style="max-width:480px; margin:0 auto 16px;">${guideHTML()}</div><button class="btn gold" onclick="confirmBoard()">${pend?'Confirm Placement':'Done'}</button>`);
  renderEditorBoard();
}
function renderEditorBoard(){
  const b=document.getElementById('editor-board'); b.innerHTML='';
  G.board.forEach((r,i)=>{
    const cell=document.createElement('div'); cell.className='cell'+(r?'':' empty'); cell.dataset.i=i;
    if(r){ cell.innerHTML=runeInner(r); cell.firstChild.setAttribute('draggable','true'); }
    cell.addEventListener('dragover',e=>{e.preventDefault(); cell.classList.add('dragover');});
    cell.addEventListener('dragleave',()=>cell.classList.remove('dragover'));
    cell.addEventListener('drop',e=>{e.preventDefault(); cell.classList.remove('dragover'); onEditorDrop(i);});
    cell.addEventListener('click',()=>onEditorClick(i));
    if(r){ const rn=cell.firstChild; rn.addEventListener('dragstart',()=>{dragFrom=i; rn.classList.add('dragging');}); rn.addEventListener('dragend',()=>{dragFrom=null; renderEditorBoard();}); }
    b.appendChild(cell);
  });
}
function onEditorDrop(to){ if(dragFrom===null||dragFrom===to) return; const t=G.board[to]; G.board[to]=G.board[dragFrom]; G.board[dragFrom]=t; dragFrom=null; renderEditorBoard(); }
function onEditorClick(i){ if(!editorPlacing||!G._pending) return; G.board[i]=G._pending; G._pending=null; editorPlacing=false; openBoardEditor(false); }
function confirmBoard(){ if(G._pending){ const empty=G.board.indexOf(null); if(empty>=0){ G.board[empty]=G._pending; G._pending=null; } else { flashHint('Board full — click a rune to replace it.'); return; } } closeOverlay(); if(G.inCombat) renderCombat(); else returnToMap(); }

/* ---------------- RENDER ---------------- */
function runeInner(r){ return `<div class="rune ${r.elem}"><span class="rcost">${r.cost}</span><span class="glyph">${sigil(r.elem)}</span><span class="rname">${r.name}</span></div>`; }

function intentMarkup(it){
  if(it.t==='atk') return `<div class="intent atk">${UI_ICON.sword} ${it.dmg}</div>`;
  if(it.t==='def') return `<div class="intent def">${UI_ICON.shield} ${it.v}</div>`;
  if(it.t==='buff') return `<div class="intent buff">${UI_ICON.buff} Buff</div>`;
  return '';
}
function statusMarkup(e){
  let s='';
  if(e.burn>0) s+=`<span>${sigil('fire')}${e.burn}</span>`;
  if(e.freeze>0) s+=`<span>${sigil('ice')}${e.freeze}</span>`;
  if(e.block>0) s+=`<span>${UI_ICON.shield}${e.block}</span>`;
  if(e.strength>0) s+=`<span>${UI_ICON.buff}${e.strength}</span>`;
  return s;
}
function buildEnemies(){
  const ec=document.getElementById('enemies'); ec.innerHTML='';
  G.enemies.forEach((e,idx)=>{
    const div=document.createElement('div');
    div.className='enemy'+(e.big?' big':'');
    div.dataset.eidx=idx;
    div.onclick=()=>{ if(e.hp>0){ G.target=idx; updateEnemies(); } };
    div.innerHTML=`<div class="intent-wrap"></div>
      <div class="sprite ${e.big?'boss ':''}${FLOATERS.has(e.id)?'float':'ground'}" style="animation-delay:${(idx*-0.8).toFixed(2)}s">${CREATURE[e.id]}</div>
      <div class="ename">${e.name}</div>
      <div class="bar ebar"><span class="hpfill"></span><span class="lab"></span></div>
      <div class="estatus"></div>`;
    e._el=div;
    e._intent=div.querySelector('.intent-wrap');
    e._hpfill=div.querySelector('.hpfill');
    e._lab=div.querySelector('.lab');
    e._status=div.querySelector('.estatus');
    e._wasDead=e.hp<=0;
    ec.appendChild(div);
  });
  updateEnemies();
}
function updateEnemies(){
  G.enemies.forEach((e,idx)=>{
    const el=e._el; if(!el) return;
    const dead=e.hp<=0;
    if(dead && !e._wasDead){ el.classList.add('dying'); e._wasDead=true; }
    el.classList.toggle('dead', dead);
    el.classList.toggle('targeted', idx===G.target && !dead);
    e._hpfill.style.width=Math.max(0,e.hp/e.maxHp*100)+'%';
    e._lab.textContent=`${Math.max(0,e.hp)}/${e.maxHp}`;
    e._intent.innerHTML=(!dead && e.intent)?intentMarkup(e.intent):'';
    e._status.innerHTML=statusMarkup(e);
  });
}
/* FX helpers */
function hitEnemy(e){ const el=e._el; if(!el) return; el.classList.remove('hit'); void el.offsetWidth; el.classList.add('hit'); clearTimeout(el._ht); el._ht=setTimeout(()=>el.classList.remove('hit'),360); }
function lungeEnemy(e){ const el=e._el; if(!el) return; el.classList.remove('lunge'); void el.offsetWidth; el.classList.add('lunge'); clearTimeout(el._lt); el._lt=setTimeout(()=>el.classList.remove('lunge'),440); }
function shakeScreen(){ const c=document.getElementById('combat'); c.classList.remove('shake'); void c.offsetWidth; c.classList.add('shake'); clearTimeout(c._st); c._st=setTimeout(()=>c.classList.remove('shake'),450); }
function hurtFlash(){ const f=document.getElementById('hurt-flash'); if(!f) return; f.classList.remove('on'); void f.offsetWidth; f.classList.add('on'); clearTimeout(f._ft); f._ft=setTimeout(()=>f.classList.remove('on'),430); }
function ringFlare(a,color){ const d=document.createElement('div'); d.className='ring-flare'; d.style.left=a.x+'px'; d.style.top=a.y+'px'; d.style.setProperty('--rc',color); document.body.appendChild(d); setTimeout(()=>d.remove(),580); }
function reactionText(a,txt){ const d=document.createElement('div'); d.className='react-pop'; d.textContent=txt; d.style.left=a.x+'px'; d.style.top=(a.y-8)+'px'; document.body.appendChild(d); setTimeout(()=>d.remove(),980); }
function blockShimmer(){ const p=document.querySelector('.hero-panel'); if(!p) return; p.classList.remove('shimmer'); void p.offsetWidth; p.classList.add('shimmer'); clearTimeout(p._bt); p._bt=setTimeout(()=>p.classList.remove('shimmer'),560); }
function hpBarFlash(){ const b=document.getElementById('php-fill').parentElement; b.classList.remove('hphit'); void b.offsetWidth; b.classList.add('hphit'); clearTimeout(b._ht); b._ht=setTimeout(()=>b.classList.remove('hphit'),440); }
function cellAnchor(idx){ const cells=document.querySelectorAll('#board .cell'); const cell=cells[idx]; if(!cell) return playerAnchor(); const r=cell.getBoundingClientRect(); return {x:r.left+r.width/2, y:r.top+r.height/2}; }
const PROJ_MS=185;
function projectile(from,to,elem,onHit){
  const p=document.createElement('div'); p.className='projectile';
  p.style.left=from.x+'px'; p.style.top=from.y+'px';
  const core=document.createElement('div'); core.className='proj-core proj-'+elem;
  const ang=Math.atan2(to.y-from.y, to.x-from.x)*180/Math.PI;
  core.style.setProperty('--ang', ang+'deg');
  p.appendChild(core);
  document.body.appendChild(p);
  requestAnimationFrame(()=>{ p.style.transform=`translate(${to.x-from.x}px, ${to.y-from.y}px)`; });
  setTimeout(()=>{ p.remove(); if(onHit) onHit(); }, PROJ_MS);
}
function impactPunch(strong){ const a=document.getElementById('app'); a.classList.remove('punch','punch-lg'); void a.offsetWidth; a.classList.add(strong?'punch-lg':'punch'); clearTimeout(a._pt); a._pt=setTimeout(()=>a.classList.remove('punch','punch-lg'), strong?260:180); }
function screenWipe(cb){ const w=document.createElement('div'); w.className='wipe'; document.body.appendChild(w); setTimeout(()=>{ if(cb)cb(); }, 330); setTimeout(()=>w.remove(), 760); }
function victoryFlash(cb){
  const v=document.createElement('div'); v.className='victory-flash';
  v.innerHTML=`<div class="vf-rays"></div><div class="vf-text">VICTORY</div>`;
  document.body.appendChild(v);
  setTimeout(()=>{ v.remove(); if(cb)cb(); }, 1050);
}
function renderCombat(){
  const phpFill=document.getElementById('php-fill');
  phpFill.style.width=Math.max(0,G.hp/G.maxHp*100)+'%';
  phpFill.parentElement.classList.toggle('low', G.hp>0 && G.hp/G.maxHp<0.3);
  document.getElementById('php-lab').textContent=`${Math.max(0,G.hp)}/${G.maxHp}`;
  const pb=document.getElementById('pblock'); pb.innerHTML=`${UI_ICON.shield} ${G.block}`; pb.classList.toggle('on',G.block>0);
  const orbs=document.getElementById('orbs'); orbs.innerHTML=''; const fresh=G._orbFresh; G._orbFresh=false;
  for(let i=0;i<G.maxEnergy;i++){const o=document.createElement('div'); o.className='orb'+(i<G.energy?' on':'')+(fresh&&i<G.energy?' fresh':''); o.style.animationDelay=(i*0.06)+'s'; orbs.appendChild(o);}

  const bb=document.getElementById('brand-btn'); if(bb){ bb.disabled=G.flameBrandUsed||!G.playerTurn; bb.style.opacity=G.flameBrandUsed?'.35':''; }

  updateEnemies();

  const bd=document.getElementById('board'); bd.innerHTML='';
  G.board.forEach((r,i)=>{
    const cell=document.createElement('div'); cell.className='cell'+(r?'':' empty'); cell.dataset.i=i;
    if(r){ cell.innerHTML=runeInner(r); const rn=cell.firstChild; if(r.used) rn.classList.add('used');
      if(G.playerTurn&&!r.used&&G.energy>=r.cost){ rn.classList.add('castable'); rn.onclick=()=>castRune(i); } }
    bd.appendChild(cell);
  });
  document.getElementById('board-hint').textContent = G.playerTurn ? `Target: ${currentTarget()?currentTarget().name:'—'} · click a foe to switch` : 'Enemy turn…';
}

/* ---------------- FX ---------------- */
function playerAnchor(){ const el=document.getElementById('combat-hero')||document.getElementById('board'); const r=el.getBoundingClientRect(); return {x:r.left+r.width/2, y:r.top+r.height/2}; }
function enemyAnchor(e){ const el=e&&e._el?e._el:document.querySelector(`.enemy[data-eidx="${G.enemies.indexOf(e)}"]`); if(!el) return {x:innerWidth/2,y:200}; const r=el.getBoundingClientRect(); return {x:r.left+r.width/2, y:r.top+42}; }
function floatText(txt,a,color){ const d=document.createElement('div'); d.className='float'; d.textContent=txt; d.style.color=color||'#fff'; d.style.left=(a.x-10)+'px'; d.style.top=a.y+'px'; document.body.appendChild(d); setTimeout(()=>d.remove(),1000); }
function burst(a,color,n){ n=n||6; for(let i=0;i<n;i++){ const p=document.createElement('div'); p.className='particle'; const ang=Math.random()*6.28, dist=18+Math.random()*30; p.style.left=a.x+'px'; p.style.top=a.y+'px'; p.style.setProperty('--dx',(Math.cos(ang)*dist)+'px'); p.style.setProperty('--dy',(Math.sin(ang)*dist)+'px'); p.style.setProperty('--pc',color); document.body.appendChild(p); setTimeout(()=>p.remove(),620); } }
function flashHint(t){ const h=document.getElementById('board-hint'); if(h){ h.textContent=t; h.style.color='var(--danger)'; setTimeout(()=>{h.style.color=''; renderCombat();},1200); } }

/* ---------------- LOG / OVERLAY ---------------- */
function log(html){ const l=document.getElementById('log'); const d=document.createElement('div'); d.className='l'; d.innerHTML=html; l.appendChild(d); l.scrollTop=l.scrollHeight; }
function logClear(){ document.getElementById('log').innerHTML=''; }
function overlay(inner){ document.getElementById('overlay-mount').innerHTML=`<div class="overlay"><div class="modal">${inner}</div></div>`; }
function closeOverlay(){ document.getElementById('overlay-mount').innerHTML=''; }
function gameOver(){ overlay(`<h2 style="color:var(--danger)">You Fall</h2><p>The tower claims another aspirant on floor ${G.floor}.</p><button class="btn primary" onclick="location.reload()">Climb Again</button>`); }
function victoryScreen(){ overlay(`<h2 style="color:var(--gold)">The Warden Falls</h2><p>You reach the tower's peak. The first ascent is complete — and the flame remembers you.</p><button class="btn primary" onclick="location.reload()">Climb Again</button>`); }

/* ---------------- GUIDE ---------------- */
function guideHTML(){
  const p=(a,b,name)=>`${sigil(a)}+${sigil(b)} <b>${name}</b>`;
  return `<div class="rg-title">Elemental Reactions (adjacent runes)</div>
    ${p('fire','ice','Shatter')} burst · ${p('fire','storm','Wildfire')} splash all<br>
    ${p('fire','earth','Magma')} Burn · ${p('ice','storm','Flashfreeze')} skip turn<br>
    ${p('ice','earth','Permafrost')} +Block · ${p('storm','earth','Ground Current')} pierce<br>
    Same element neighbors <b>Attune</b> (+40% each).`;
}

/* ---------------- INIT ---------------- */
document.getElementById('title-hero').innerHTML=HERO_FLAMEKNIGHT;
document.getElementById('combat-hero').innerHTML=HERO_FLAMEKNIGHT;
document.getElementById('title-guide').innerHTML=guideHTML();
document.getElementById('ic-heart').innerHTML=UI_ICON.heart;
document.getElementById('ic-energy').innerHTML=UI_ICON.energy;
document.getElementById('ic-floor').innerHTML=UI_ICON.floor;
document.getElementById('ic-endturn').innerHTML=UI_ICON.refresh;
document.body.insertAdjacentHTML('beforeend','<div id="hurt-flash"></div>');
(function initEmbers(){
  const tb=document.querySelector('.tower-bg'); if(!tb) return;
  for(let i=0;i<16;i++){
    const e=document.createElement('div'); e.className='ember';
    const size=(2+Math.random()*3).toFixed(1);
    e.style.left=(Math.random()*100)+'%';
    e.style.width=e.style.height=size+'px';
    e.style.animationDuration=(6+Math.random()*7).toFixed(1)+'s';
    e.style.animationDelay=(-Math.random()*13).toFixed(1)+'s';
    e.style.setProperty('--drift',(Math.random()*80-40).toFixed(0)+'px');
    tb.appendChild(e);
  }
})();

window.addEventListener('keydown',e=>{ if(e.code==='Space'&&G&&G.inCombat&&G.playerTurn&&!document.querySelector('.overlay')){ e.preventDefault(); endTurn(); } });
</script>
</body>
</html>
